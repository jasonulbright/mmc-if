<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <!-- Address bar -->
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnUp" Grid.Column="0" Content="&#x2191;"
                        MinWidth="36" Padding="6,2,6,2" Margin="0,0,6,0"
                        ToolTip="Up one level"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <TextBox x:Name="txtPath" Grid.Column="1"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         FontFamily="Cascadia Code, Consolas"
                         Controls:TextBoxHelper.Watermark="C:\, file path, or archive..."/>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnGo" Grid.Column="2" Content="Go"
                        MinWidth="54" Margin="6,0,0,0"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="treeDirs" Grid.Column="0" BorderThickness="0"/>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{DynamicResource MahApps.Brushes.Gray8}"/>

            <DataGrid x:Name="gridFiles" Grid.Column="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      ColumnHeaderHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header=""          Width="34"  Binding="{Binding Icon}"/>
                    <DataGridTextColumn Header="Name"      Width="300" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Type"      Width="80"  Binding="{Binding Type}"/>
                    <DataGridTextColumn Header="Size"      Width="100" Binding="{Binding Size}"/>
                    <DataGridTextColumn Header="Modified"  Width="150" Binding="{Binding Modified}"/>
                    <DataGridTextColumn Header="Attributes" Width="*"  Binding="{Binding Attributes}"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="mnuCopyPath" Header="Copy Full Path"/>
                        <MenuItem x:Name="mnuOpenExplorer" Header="Open in Windows Explorer"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
