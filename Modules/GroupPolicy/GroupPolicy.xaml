<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StackPanel Orientation="Horizontal">
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnRun" Content="Run gpresult"
                        MinWidth="120" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnOpenHtml" Content="Open HTML Report"
                        MinWidth="130" Padding="8,4,8,4" Margin="10,0,0,0"
                        Visibility="Collapsed"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <TextBlock Text="Runs gpresult /h to the user's temp dir. Read-only."
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
            </StackPanel>
        </Border>

        <TextBox x:Name="txtOutput"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Code, Consolas, Courier New"
                 FontSize="11"
                 BorderThickness="0"
                 Margin="6"/>
    </DockPanel>
</UserControl>
