<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StackPanel Orientation="Horizontal">
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnRefresh" Content="Refresh"
                        MinWidth="80" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <TextBox x:Name="txtHost" MinWidth="200" Margin="14,0,6,0"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Controls:TextBoxHelper.Watermark="host or IP (e.g. 8.8.8.8)"/>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnPing" Content="Ping"
                        MinWidth="70" Padding="8,4,8,4" Margin="0,0,6,0"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnTracert" Content="Tracert"
                        MinWidth="70" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <TextBlock Text="Read-only. Adapter state and DHCP release/renew not included (require admin)."
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Height="220"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="OUTPUT"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           Margin="8,6,0,4"/>
                <TextBox x:Name="txtOutput"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11" BorderThickness="0"
                         Margin="4,0,4,4"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="gridAdapters"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  RowHeaderWidth="0" BorderThickness="0" ColumnHeaderHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"         Width="160" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Interface"    Width="240" Binding="{Binding InterfaceDescription}"/>
                <DataGridTextColumn Header="Status"       Width="90"  Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Speed"        Width="100" Binding="{Binding LinkSpeed}"/>
                <DataGridTextColumn Header="MAC"          Width="150" Binding="{Binding MacAddress}"/>
                <DataGridTextColumn Header="IPv4"         Width="150" Binding="{Binding IPv4}"/>
                <DataGridTextColumn Header="Gateway"      Width="*"   Binding="{Binding Gateway}"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="mnuCopyIp"  Header="Copy IPv4"/>
                    <MenuItem x:Name="mnuCopyMac" Header="Copy MAC"/>
                    <MenuItem x:Name="mnuCopyAll" Header="Copy All Details"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</UserControl>
