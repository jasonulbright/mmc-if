<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StackPanel Orientation="Horizontal">
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnRefresh" Content="Refresh"
                        MinWidth="80" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <TextBlock Text="Certificate stores via .NET X509Store. Read-only."
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="treeCerts" Grid.Column="0" BorderThickness="0"/>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{DynamicResource MahApps.Brushes.Gray8}"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="150"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="180" MinHeight="80"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="gridCerts" Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          BorderThickness="0"
                          ColumnHeaderHeight="30">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Subject"       Width="240" Binding="{Binding Subject}"/>
                        <DataGridTextColumn Header="Issuer"        Width="200" Binding="{Binding Issuer}"/>
                        <DataGridTextColumn Header="Expires"       Width="130" Binding="{Binding Expires}"/>
                        <DataGridTextColumn Header="Thumbprint"    Width="180" Binding="{Binding Thumbprint}"/>
                        <DataGridTextColumn Header="Friendly Name" Width="*"   Binding="{Binding FriendlyName}"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuCopyThumb"   Header="Copy Thumbprint"/>
                            <MenuItem x:Name="mnuCopySubject" Header="Copy Subject"/>
                            <MenuItem x:Name="mnuCopyDetail"  Header="Copy Full Details"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                              Background="{DynamicResource MahApps.Brushes.Gray8}"/>

                <Border Grid.Row="2" BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                        BorderThickness="0,1,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="CERTIFICATE DETAIL"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                   Margin="8,6,0,4"/>
                        <TextBox x:Name="txtDetail"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="11" BorderThickness="0"
                                 Margin="4,0,4,4"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
