<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cboView" MinWidth="110" VerticalAlignment="Center">
                    <ComboBoxItem Content="Users" IsSelected="True"/>
                    <ComboBoxItem Content="Groups"/>
                </ComboBox>
                <TextBox x:Name="txtFilter" MinWidth="240"
                         Margin="10,0,10,0"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Controls:TextBoxHelper.Watermark="Filter by name, description..."/>
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnRefresh" Content="Refresh"
                        MinWidth="80" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
            </StackPanel>
        </Border>

        <!-- Detail pane -->
        <Border DockPanel.Dock="Bottom" Height="180"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="DETAIL"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           Margin="8,6,0,4"/>
                <TextBox x:Name="txtDetail"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11" BorderThickness="0"
                         Margin="4,0,4,4"/>
            </DockPanel>
        </Border>

        <Grid>
            <DataGrid x:Name="gridUsers"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      RowHeaderWidth="0" BorderThickness="0" ColumnHeaderHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"           Width="150" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Full Name"      Width="180" Binding="{Binding FullName}"/>
                    <DataGridTextColumn Header="Enabled"        Width="80"  Binding="{Binding EnabledStr}"/>
                    <DataGridTextColumn Header="Password Last Set" Width="160" Binding="{Binding PasswordLastSet}"/>
                    <DataGridTextColumn Header="Last Logon"     Width="160" Binding="{Binding LastLogon}"/>
                    <DataGridTextColumn Header="Description"    Width="*"   Binding="{Binding Description}"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="mnuUsrCopyName" Header="Copy Name"/>
                        <MenuItem x:Name="mnuUsrCopySid"  Header="Copy SID"/>
                        <MenuItem x:Name="mnuUsrCopyDetail" Header="Copy Details"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <DataGrid x:Name="gridGroups" Visibility="Collapsed"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      RowHeaderWidth="0" BorderThickness="0" ColumnHeaderHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"        Width="240" Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Description" Width="*"   Binding="{Binding Description}"/>
                    <DataGridTextColumn Header="Members"     Width="100" Binding="{Binding MemberCount}"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="mnuGrpCopyName"   Header="Copy Name"/>
                        <MenuItem x:Name="mnuGrpCopySid"    Header="Copy SID"/>
                        <MenuItem x:Name="mnuGrpCopyDetail" Header="Copy Details"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Grid>
    </DockPanel>
</UserControl>
