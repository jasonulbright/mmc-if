<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Log:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="0"/>
                <ComboBox x:Name="cboLog" Grid.Column="1" VerticalAlignment="Center">
                    <ComboBoxItem Content="Application" IsSelected="True"/>
                    <ComboBoxItem Content="System"/>
                    <ComboBoxItem Content="Security"/>
                    <ComboBoxItem Content="Setup"/>
                </ComboBox>

                <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="3"/>
                <ComboBox x:Name="cboLevel" Grid.Column="4" VerticalAlignment="Center">
                    <ComboBoxItem Content="All Levels" IsSelected="True"/>
                    <ComboBoxItem Content="Critical"/>
                    <ComboBoxItem Content="Error"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Information"/>
                </ComboBox>

                <TextBlock Text="Time:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="6"/>
                <ComboBox x:Name="cboTime" Grid.Column="7" VerticalAlignment="Center">
                    <ComboBoxItem Content="Last 1 Hour"/>
                    <ComboBoxItem Content="Last 24 Hours" IsSelected="True"/>
                    <ComboBoxItem Content="Last 7 Days"/>
                    <ComboBoxItem Content="Last 30 Days"/>
                    <ComboBoxItem Content="All Time"/>
                </ComboBox>

                <TextBlock Text="Max:" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="9"/>
                <TextBox x:Name="txtMax" Grid.Column="10" Text="500"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnLoad" Grid.Column="12" Content="Load Events"
                        MinWidth="110" Padding="10,4,10,4" Margin="6,0,6,0"
                        VerticalAlignment="Center"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>

                <TextBox x:Name="txtFilter" Grid.Column="13"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Controls:TextBoxHelper.Watermark="Filter by source, message, or event ID..."
                         Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <!-- Detail panel at bottom -->
        <Border DockPanel.Dock="Bottom" Height="140"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="EVENT DETAIL"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           Margin="8,6,0,4"/>
                <TextBox x:Name="txtDetail"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11"
                         BorderThickness="0"
                         Margin="4,0,4,4"/>
            </DockPanel>
        </Border>

        <!-- Events grid fills remaining -->
        <DataGrid x:Name="gridEvents"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  BorderThickness="0"
                  ColumnHeaderHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Level"    Width="90"  Binding="{Binding Level}"/>
                <DataGridTextColumn Header="Date/Time" Width="160" Binding="{Binding Time}"/>
                <DataGridTextColumn Header="Source"   Width="200" Binding="{Binding Source}"/>
                <DataGridTextColumn Header="Event ID" Width="80"  Binding="{Binding EventId}"/>
                <DataGridTextColumn Header="Message"  Width="*"   Binding="{Binding Message}"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="mnuCopyMessage" Header="Copy Full Message"/>
                    <MenuItem x:Name="mnuCopyRow" Header="Copy Row Summary"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

    </DockPanel>
</UserControl>
