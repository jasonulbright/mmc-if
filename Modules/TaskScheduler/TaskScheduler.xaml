<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6,8,6"
                Background="{DynamicResource MahApps.Brushes.Gray10}">
            <StackPanel Orientation="Horizontal">
                <Button Controls:ControlsHelper.ContentCharacterCasing="Normal" x:Name="btnRefresh" Content="Refresh"
                        MinWidth="80" Padding="8,4,8,4"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <TextBox x:Name="txtFilter" MinWidth="300" Margin="10,0,0,0"
                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Controls:TextBoxHelper.Watermark="Filter by name, path, or author..."/>
                <CheckBox x:Name="chkHideMicrosoft" Content="Hide Microsoft tasks"
                          VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="True"/>
                <TextBlock Text="Read-only. Enable/disable/run removed for non-admin target."
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}" FontSize="11"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Height="220"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="TASK DETAIL"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           Margin="8,6,0,4"/>
                <TextBox x:Name="txtDetail"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11" BorderThickness="0"
                         Margin="4,0,4,4"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="gridTasks"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  RowHeaderWidth="0" BorderThickness="0" ColumnHeaderHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Task Name"    Width="280" Binding="{Binding TaskName}"/>
                <DataGridTextColumn Header="Path"         Width="280" Binding="{Binding TaskPath}"/>
                <DataGridTextColumn Header="State"        Width="100" Binding="{Binding State}"/>
                <DataGridTextColumn Header="Author"       Width="200" Binding="{Binding Author}"/>
                <DataGridTextColumn Header="Last Run"     Width="150" Binding="{Binding LastRunTime}"/>
                <DataGridTextColumn Header="Next Run"     Width="150" Binding="{Binding NextRunTime}"/>
                <DataGridTextColumn Header="Last Result"  Width="*"   Binding="{Binding LastResultText}"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="mnuCopyName" Header="Copy Task Name"/>
                    <MenuItem x:Name="mnuCopyPath" Header="Copy Full Path"/>
                    <MenuItem x:Name="mnuCopyDetail" Header="Copy Details"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</UserControl>
